# OpenAI API key for semantic analysis (optional). Leave empty to disable.
OPENAI_API_KEY=
# Override model (default: gpt-4.1)
SKILLGUARD_MODEL=gpt-4.1
# Set to 1 to disable semantic analysis globally.
SKILLGUARD_DISABLE_SEMANTIC=
# Log level (DEBUG, INFO, WARNING, ERROR)
SKILLGUARD_LOG_LEVEL=WARNING
